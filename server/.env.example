# Copiez ce fichier en ".env" et renseignez les valeurs pour activer les
# fonctionnalités optionnelles. (Le serveur lit déjà process.env ; pour charger
# automatiquement un .env, lancez le serveur avec : node --env-file=.env src/index.js)

# --- Compte administrateur (par défaut admin@shoptasapp.com / admin1234) ---
ADMIN_EMAIL=admin@shoptasapp.com
ADMIN_PASSWORD=changez-moi

# --- Secret JWT (à changer en production) ---
JWT_SECRET=un-secret-long-et-aleatoire

# --- Connexion Google (Google Cloud Console > Identifiants > ID client OAuth) ---
# Type "Application Web", origine JavaScript autorisée : http://localhost:5173
GOOGLE_CLIENT_ID=votre-client-id.apps.googleusercontent.com

# --- E-mails (SMTP) : sans ces valeurs, les e-mails s'affichent dans la console ---
SMTP_HOST=smtp.exemple.com
SMTP_PORT=587
SMTP_USER=utilisateur
SMTP_PASS=mot-de-passe
MAIL_FROM=ShopTaSapp <no-reply@shoptasapp.com>
